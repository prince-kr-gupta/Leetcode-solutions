class Solution {
public:
    int reverse(int x) {
        long long ans = 0;

        while(x!=0) {
           int n = x%10;
           ans = (ans*10) + n;
           x = x/10;
        }
      if(ans == x){
        if(ans < 0){
            return -ans;
        }
      }
      if(ans > INT_MAX || ans < INT_MIN) return 0;
    return ans;         
    }
};
